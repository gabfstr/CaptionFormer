# CaptionFormer: track small intentional data files that the rules above ignore.
# Big binaries (pretrained backbones, precomputed CLIP feature .pkl) stay ignored.
!datasets/metadata/
!datasets/metadata/*.json
!datasets/metadata/*.npy
!tools/build_coco_plus_lvis/*.json
